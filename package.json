{
  "name": "bing-wallpapers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "npm run sync-db && next dev --turbopack",
    "start": "next start",
    "lint": "next lint",
    "sync-db": "tsx bin/sync-db.ts",
    "preview": "npm run sync-db && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run sync-db && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "npm run sync-db && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "dotenv": "^16.4.7",
    "next": "^15.5.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "wrangler": "^4.78.0"
  }
}
